//same as cascadeosc.mmm, but written with new multi-stage computation feature.
use osc::*
#stage(main)
let osc = |freq|{
  sinwave(freq,0.0)
}

#stage(macro)
fn replicate (n,gen:`(float)->float,base_rate)->`float{
    let rate = base_rate |> lift_f
    if (n>0.0){
        let gain = n |> lift_f
        `{($gen)($rate*$gain)/$gain + $replicate(n - 1.0 ,gen,base_rate) }
    }else{
        `{($gen)($rate)}
    }
}

#stage(main)

fn dsp(){
    let r =  replicate!(100, `osc,50)
    (r,r)
    
}